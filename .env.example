# Supabase Configuration
# Replace these with your actual values from the Supabase Project Settings API keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (Used for server-side REST API bypass of RLS)
# WARNING: Keep this secret and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

